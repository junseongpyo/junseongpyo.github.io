---
layout: layouts/blog-base.njk
title: Blog
description: Blog posts by Junseong Pyo.
permalink: /blog/
---

<section>
  <h2 class="section-title">Blog</h2>

  {%- set groupedPosts = collections.posts | groupPostsByGroup %}
  {%- if groupedPosts.length %}
    <div class="post-groups">
      {%- for group in groupedPosts %}
        <section class="post-group" id="{{ group.slug }}">
          <h3 class="post-group-title">{{ group.group }}</h3>
          <div class="post-list">
            {%- for post in group.posts %}
              <article class="post-list-item">
                <div class="post-list-meta">
                  <time datetime="{{ post.date | htmlDateString }}">
                    {{ post.date | readableDate }}
                  </time>
                </div>
                <h4 class="post-list-title">
                  <a href="{{ post.url }}">{{ post.data.title }}</a>
                </h4>
                {%- if post.data.description %}
                  <p class="post-list-description">
                    {{ post.data.description }}
                  </p>
                {%- endif %}
              </article>
            {%- endfor %}
          </div>
        </section>
      {%- endfor %}
    </div>
  {%- else %}
    <p class="post-list-description">No posts yet.</p>
  {%- endif %}
</section>
